{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,      // разрешаем импорт .js/.jsx файлов
    "checkJs": false,     // не проверять .js/.jsx на типы
    "noImplicitAny": false // можно отключить для упрощения
  
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}